#!/usr/bin/env bash
# ANSIBLE MANAGED — scanner role
# Hourly health check: NAS mount + scanner device availability.
# Both checks run independently so a scanner failure does not mask
# (or skip) a missing mount.

set -euo pipefail

MOUNTPOINT="{{ scanner_consume_mountpoint }}"
MOUNT_TYPE="{{ scanner_consume_mount_type }}"
SCANNER_USB_ID="{{ scanner_usb_vendor_id }}:{{ scanner_usb_product_id }}"

log_info()  { logger -t scanner-healthcheck -p user.info  "$*"; }
log_warn()  { logger -t scanner-healthcheck -p user.warning "$*"; }
log_error() { logger -t scanner-healthcheck -p user.err   "$*"; }

# Derive the automount unit name from the mountpoint
# (e.g. /mnt/paperless-consume → mnt-paperless\x2dconsume.automount).
automount_unit() {
    systemd-escape --suffix=automount --path "${MOUNTPOINT}"
}

check_mount() {
    if mountpoint -q "${MOUNTPOINT}"; then
        log_info "mount ok: ${MOUNTPOINT}"
        return 0
    fi

    if [ "${MOUNT_TYPE}" = "cifs" ]; then
        local unit
        unit="$(automount_unit)"
        log_warn "mount missing: ${MOUNTPOINT} — restarting ${unit}"
        if systemctl restart "${unit}" >/dev/null 2>&1; then
            sleep 2
            if mountpoint -q "${MOUNTPOINT}"; then
                log_info "mount recovered via ${unit}"
                return 0
            fi
        fi
    elif [ "${MOUNT_TYPE}" = "local" ]; then
        log_warn "mount missing: ${MOUNTPOINT} — attempting mount from fstab or systemd"
        if mount "${MOUNTPOINT}" >/dev/null 2>&1; then
            sleep 2
            if mountpoint -q "${MOUNTPOINT}"; then
                log_info "mount recovered via mount(8)"
                return 0
            fi
        fi
    fi

    log_error "mount recovery failed for ${MOUNTPOINT}"
    return 1
}

check_scanner() {
    # Probe for USB device presence, NOT `scanimage -L`:
    #  - scanbd holds the USB interface exclusively in direct mode, so
    #    `scanimage -L` returns LIBUSB_ERROR_BUSY during normal operation.
    #  - the service runs with NoNewPrivileges=true, so `sudo` (setuid) can't
    #    escalate anyway. lsusb runs as root here and needs no escalation.
    if lsusb -d "${SCANNER_USB_ID}" >/dev/null 2>&1; then
        log_info "scanner present on USB (${SCANNER_USB_ID})"
        return 0
    fi
    log_error "scanner not present on USB (${SCANNER_USB_ID})"
    return 1
}

mount_rc=0
scanner_rc=0
check_mount    || mount_rc=$?
check_scanner  || scanner_rc=$?

# Service exits 0 unless both checks fail — a missing scanner alone
# should not flap the unit; the journal entry is the alert surface.
if [ "${mount_rc}" -ne 0 ] && [ "${scanner_rc}" -ne 0 ]; then
    exit 1
fi
exit 0
